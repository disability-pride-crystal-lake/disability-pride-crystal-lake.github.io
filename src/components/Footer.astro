---
import CallToAction from './CallToAction.astro'
import Logo from './Logo.astro'
import { Heading, Link } from 'accessible-astro-components'
import { Icon } from 'astro-icon/components'

/**
 * Footer Component
 *
 * @description A component that displays the footer of the website
 */
const currentYear = new Date().getFullYear()
---

<footer>
  <CallToAction
    title="Join Us on July 25, 2026"
    link="/accessibility"
    linkText="Plan Your Visit"
  />
  <section class="py-20">
    <Heading level="h2" class="sr-only">Footer</Heading>
    <div class="container grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-4">
      <div class="flex flex-col gap-4">
        <Heading level="h3" size="h6">Event Pages</Heading>
        <ul class="flex flex-col gap-2">
          <li><Link href="/">Home</Link></li>
          <li><Link href="/accessibility">Accessibility &amp; Directions</Link></li>
          <li><Link href="/vendor">Vendor Registration</Link></li>
          <li><Link href="/sponsorship">Sponsorship</Link></li>
          <li><Link href="/about">About Us</Link></li>
        </ul>
      </div>
      <div class="flex flex-col gap-4">
        <Heading level="h3" size="h6">Event Details</Heading>
        <ul class="flex flex-col gap-2">
          <li><strong>Date:</strong> July 25, 2026</li>
          <li><strong>Time:</strong> 10:00 AM &ndash; 1:00 PM</li>
          <li><strong>Location:</strong> McHenry County College</li>
          <li>8900 US-14, Crystal Lake, IL 60012</li>
          <li><strong>Venues:</strong> Luecht Auditorium, Cafeteria, &amp; Commons (Building B)</li>
        </ul>
      </div>
      <div class="flex flex-col gap-4">
        <Heading level="h3" size="h6">Contact</Heading>
        <ul class="flex flex-col gap-2">
          <li><strong>Z Advocacy NFP</strong></li>
          <li>
            Phone: <a href="tel:+18472174686" aria-label="Call Z Advocacy at (847) 217-4686">(847) 217-4686</a>
          </li>
          <li>
            <a
              href="mailto:sara.zadvocacy+info@gmail.com"
              aria-label="Email Z Advocacy for General Inquiries"
            >
              Email Z Advocacy for General Inquiries
            </a>
          </li>
          <li>
            <Link href="mailto:sara.zadvocacy+vendors@gmail.com?subject=Disability%20Pride%20Vendor%20Inquiry%20-%202026">
              Vendor Inquiries
            </Link>
          </li>
          <li>
            <Link href="mailto:sara.zadvocacy+sponsors@gmail.com?subject=Disability%20Pride%20Sponsorship%20Inquiry%20-%202026">
              Sponsorship Inquiries
            </Link>
          </li>
        </ul>
      </div>
      <div class="flex flex-col gap-4">
        <Logo loading="lazy" />
        <p class="leading-[1.75]">
          Organized by <strong>Z Advocacy NFP</strong>, a registered 501(c)(3) tax-exempt organization dedicated to expanding access, resources, and celebrating the lived experiences of individuals within the disability community.
        </p>
        <Heading level="h3" size="h6">Follow Us</Heading>
        <ul class="flex flex-col gap-2">
          <li>
            <a
              href="https://www.facebook.com/profile.php?id=61575995903833"
              target="_blank"
              rel="noopener noreferrer"
              style="display: inline-flex; align-items: center; gap: 0.5rem;"
              aria-label="Disability Pride Event on Facebook (opens in a new tab)"
            >
              <Icon aria-hidden="true" name="lucide:external-link" size="1.25rem" />
              Disability Pride Event
            </a>
          </li>
          <li>
            <a
              href="https://www.facebook.com/profile.php?id=61589329260319"
              target="_blank"
              rel="noopener noreferrer"
              style="display: inline-flex; align-items: center; gap: 0.5rem;"
              aria-label="Z Advocacy NFP on Facebook (opens in a new tab)"
            >
              <Icon aria-hidden="true" name="lucide:external-link" size="1.25rem" />
              Z Advocacy NFP
            </a>
          </li>
        </ul>
      </div>
    </div>
  </section>
  <section class="py-8">
    <div class="container flex flex-col gap-4 md:flex-row md:justify-between">
      <p>
        &copy; {currentYear} Z Advocacy NFP. All rights reserved.
      </p>
    </div>
  </section>
</footer>

<style>
  section {
    border-top: 1px solid var(--border-color-subtle);
  }
</style>
