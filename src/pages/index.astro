---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import Feature from '@components/Feature.astro'
import { Heading, Link } from 'accessible-astro-components'
import { Icon } from 'astro-icon/components'
import { Image } from 'astro:assets'
import flyerImage from '@assets/img/event-flyer.jpg'
---

<DefaultLayout
  title="2nd Annual Crystal Lake Disability Pride Event — July 25, 2026"
  description="Join us July 25, 2026 at McHenry County College for the 2nd Annual Crystal Lake Disability Pride Event. Celebrating the beauty, diversity, and lived experiences of people with disabilities."
  useTitleTemplate={false}
>
  <!-- Hero Section -->
  <section class="hero my-24" aria-labelledby="hero-heading">
    <div class="container">
      <div class="grid grid-cols-1 items-center gap-16 lg:grid-cols-2">
        <div class="flex flex-col items-center gap-8 md:items-start">
          <h1 id="hero-heading" class="text-center text-5xl md:text-left lg:text-7xl">
            2nd Annual <span class="text-gradient">Crystal Lake Disability Pride</span> Event
          </h1>
          <p class="text-2xl">
            <strong>July 25, 2026</strong> &middot; 10:00 AM &ndash; 1:00 PM
          </p>
          <p class="text-xl">
            McHenry County College &middot; 8900 US-14, Crystal Lake, IL 60012
          </p>
          <p class="text-xl italic">
            Celebrating the beauty, diversity, and lived experiences of people with disabilities.
          </p>
          <div class="flex flex-col gap-3 min-[500px]:flex-row">
            <Link href="/accessibility" isButton type="primary" animateOnHover animationType="boop">
              <Icon aria-hidden="true" name="lucide:map-pin" size="1.5rem" />
              Directions &amp; Access
            </Link>
            <Link href="/about" isButton type="secondary" animateOnHover animationType="boop">
              <Icon aria-hidden="true" name="lucide:info" size="1.5rem" />
              About Us
            </Link>
          </div>
        </div>
        <div>
          <Image
            src={flyerImage}
            alt="Official flyer for the Crystal Lake Disability Pride Event on July 25, 2026 at McHenry County College, featuring the Disability Pride Flag and the text: Celebrating the beauty, diversity, and lived experiences of people with disabilities."
            width={800}
            height={600}
            class="rounded-lg shadow-lg"
            loading="eager"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Event Highlights -->
  <section class="my-32" aria-labelledby="highlights-heading">
    <div class="container">
      <Heading level="h2" class="mb-4" id="highlights-heading">What to Expect on Event Day</Heading>
      <p class="mb-8 text-xl">
        Join us for a day packed with live entertainment, community connection, and essential resources — all in one fully accessible venue.
      </p>
      <div class="grid grid-cols-1 gap-12 md:grid-cols-2 lg:grid-cols-3">
        <Feature icon="lucide:music" title="Live Musicians &amp; Singers">
          Enjoy performances from talented local musicians and singers celebrating disability pride through music and art.
        </Feature>
        <Feature icon="lucide:store" title="Community Vendors">
          Browse booths from non-profit organizations and disability community-owned local businesses offering products, services, and resources.
        </Feature>
        <Feature icon="lucide:book-open" title="Essential Community Resources">
          Connect with organizations providing essential resources — from disability services and benefits navigation to healthcare, housing, and advocacy support.
        </Feature>
        <Feature icon="lucide:map-pin" title="Luecht Auditorium">
          Main stage for presentations, speakers, and live programming inside Building B at McHenry County College.
        </Feature>
        <Feature icon="lucide:accessibility" title="Fully Accessible">
          ADA-accessible parking, wheelchair-friendly pathways, ASL interpreters, and sensory-friendly quiet zones.
        </Feature>
        <Feature icon="lucide:heart" title="Community Powered">
          Organized by Z Advocacy NFP, a registered 501(c)(3) non-profit dedicated to disability rights and inclusion.
        </Feature>
      </div>
    </div>
  </section>

  <!-- Event Flyer -->
  <section class="my-32" aria-labelledby="flyer-heading">
    <div class="container max-w-2xl">
      <Heading level="h2" class="mb-8" id="flyer-heading">Event Flyer</Heading>
      <Image
        src={flyerImage}
        alt="Official flyer for the 2nd Annual Crystal Lake Disability Pride Event on July 25, 2026, showing event details including date, time, location at McHenry County College Building B, and featured activities such as musicians, singers, community vendors, and essential community resources."
        width={800}
        height={1000}
        class="mx-auto rounded-lg shadow-lg"
        loading="lazy"
      />
    </div>
  </section>

  <!-- Get Event Info -->
  <section class="my-32 bg-neutral py-16" aria-labelledby="event-info-heading">
    <div class="container max-w-2xl">
      <Heading level="h2" class="mb-4" id="event-info-heading">Get Event Info &amp; Save the Date</Heading>
      <p class="mb-8 text-lg">
        Get the event flyer and directions delivered straight to your inbox, or add the event to your calendar so you don't miss it.
      </p>
      <div class="mb-2">
        <script async src="https://subscribe-forms.beehiiv.com/v3/loader.js" data-beehiiv-form="783b07b2-4065-4956-be1d-2206506560dd"></script>
      </div>
      <p class="text-sm">We'll send you the event flyer, directions, and any updates. Unsubscribe at any time.</p>

      <div class="mt-10 border-t-2 border-current pt-8">
        <Heading level="h3" class="mb-4">Add to Your Calendar</Heading>
        <p class="mb-6">Save the date — July 25, 2026, 10:00 AM to 1:00 PM at McHenry County College.</p>
        <div class="flex flex-col gap-3 min-[500px]:flex-row">
          <a
            href="/crystal-lake-disability-pride-2026.ics"
            download="Crystal-Lake-Disability-Pride-2026.ics"
            class="button"
            style="display: inline-flex; align-items: center; gap: 0.5rem; white-space: nowrap;"
            aria-label="Download calendar file for Apple Calendar, Outlook, or other calendar apps"
          >
            <Icon aria-hidden="true" name="lucide:calendar-plus" size="1.5rem" />
            Apple / Outlook (.ics)
          </a>
          <a
            href="https://calendar.google.com/calendar/render?action=TEMPLATE&text=2nd+Annual+Crystal+Lake+Disability+Pride+Event&dates=20260725T150000Z/20260725T180000Z&details=Celebrating+the+beauty,+diversity,+and+lived+experiences+of+people+with+disabilities.+Live+musicians,+community+vendors,+essential+resources,+and+more.+Fully+accessible+venue.%0A%0AOrganized+by+Z+Advocacy+NFP.%0Ahttps://crystallakedisabilitypride.org&location=McHenry+County+College+Building+B,+8900+US-14,+Crystal+Lake,+IL+60012"
            target="_blank"
            rel="noopener noreferrer"
            class="button"
            style="display: inline-flex; align-items: center; gap: 0.5rem; white-space: nowrap;"
            aria-label="Add event to Google Calendar (opens in a new tab)"
          >
            <Icon aria-hidden="true" name="lucide:calendar-check" size="1.5rem" />
            Google Calendar
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Quick Links -->
  <section class="my-32" aria-labelledby="quick-links-heading">
    <div class="container">
      <Heading level="h2" class="mb-8" id="quick-links-heading">Get Involved</Heading>
      <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
        <div class="space-content rounded-lg border-2 border-current p-8">
          <Heading level="h3">Become a Vendor</Heading>
          <p>Showcase your products and services to the disability community at our vendor fair.</p>
          <Link href="/vendor" isButton type="primary" animateOnHover animationType="boop">
            <Icon aria-hidden="true" name="lucide:store" size="1.5rem" />
            Vendor Information
          </Link>
        </div>
        <div class="space-content rounded-lg border-2 border-current p-8">
          <Heading level="h3">Sponsor the Event</Heading>
          <p>Support your community and increase your visibility by becoming a sponsor.</p>
          <Link href="/sponsorship" isButton type="primary" animateOnHover animationType="boop">
            <Icon aria-hidden="true" name="lucide:handshake" size="1.5rem" />
            Sponsorship Details
          </Link>
        </div>
        <div class="space-content rounded-lg border-2 border-current p-8">
          <Heading level="h3">Plan Your Visit</Heading>
          <p>Detailed directions, parking info, and accessibility accommodations for the event.</p>
          <Link href="/accessibility" isButton type="primary" animateOnHover animationType="boop">
            <Icon aria-hidden="true" name="lucide:compass" size="1.5rem" />
            Accessibility Guide
          </Link>
        </div>
      </div>
    </div>
  </section>
</DefaultLayout>

<style lang="scss">
  .hero h1 {
    text-wrap: unset;
  }

  .text-gradient {
    background: linear-gradient(
      315deg,
      light-dark(var(--color-primary-300), var(--color-secondary-100)) 25%,
      light-dark(var(--color-secondary-300), var(--color-primary-200))
    );
    background-clip: border-box;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .bg-neutral {
    background-color: light-dark(var(--color-neutral-200), var(--color-neutral-800));
  }

  :global([data-beehiiv-form] iframe) {
    background: transparent !important;
    color-scheme: normal;
  }
</style>
